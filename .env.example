POSTGRES_DB=reconx
POSTGRES_USER=reconx
POSTGRES_PASSWORD=reconx
DATABASE_URL=postgresql+psycopg2://reconx:reconx@postgres:5432/reconx
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=10080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
SCAN_ALLOWED_SCHEMES=http,https
NUCLEI_TEMPLATES=
SCAN_THROTTLE_SECONDS=20
JS_FETCH_TIMEOUT_SECONDS=6
JS_FETCH_MAX_ASSETS=12
JS_FETCH_MAX_BYTES=200000
SCAN_NUCLEI_TARGET_CAP=300
SCAN_HEADER_PROBE_CAP=50
# Optional: use worker-full/Dockerfile for ffuf, katana, nmap, waybackurls, etc.
# WORKER_DOCKERFILE=worker-full/Dockerfile
SECLISTS_BASE_PATH=
ENABLE_AGGRESSIVE_SCANNING=false
INTERACTSH_SERVER_URL=
REGISTER_RATE_LIMIT=10/minute
LOGIN_RATE_LIMIT=20/minute
REFRESH_RATE_LIMIT=30/minute
READ_RATE_LIMIT=120/minute
WRITE_RATE_LIMIT=60/minute
SCAN_RATE_LIMIT=12/minute
REPORT_RATE_LIMIT=30/minute
SCHEDULED_SCAN_POLL_MINUTES=10
TAKEOVER_CNAME_INDICATORS=amazonaws.com,azurewebsites.net,herokudns.com,github.io,cloudfront.net,trafficmanager.net,fastly.net,readme.io,pantheonsite.io
VITE_API_BASE_URL=http://localhost:8000
GEMINI_API_KEY=
# Gemini retries on 429 / quota (exponential backoff, capped)
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_SECONDS=15
GEMINI_RETRY_MAX_SLEEP_SECONDS=90
# Max characters per AI request chunk (httpx/subfinder lines batched to stay under this)
AI_MAX_INPUT_CHARS=12000

# Advanced Reconnaissance Settings
ADVANCED_RECON_ENABLED=true
DEFAULT_SCAN_MODE=balanced
MAX_PARAMETER_DISCOVERY_ENDPOINTS=50
MAX_CONTENT_FUZZING_REQUESTS=100
MAX_ADAPTIVE_ANALYSIS_ENDPOINTS=20
PARAMETER_DISCOVERY_TIMEOUT_SECONDS=300
CONTENT_FUZZING_TIMEOUT_SECONDS=600
ADAPTIVE_ANALYSIS_TIMEOUT_SECONDS=300

# ── Database Connection Pool ──────────────────────────────────────────────────
# SQLAlchemy connection pool size (number of persistent connections)
DB_POOL_SIZE=20
# Maximum overflow connections above pool_size
DB_MAX_OVERFLOW=30
# Seconds before a connection is recycled (prevents stale connections)
DB_POOL_RECYCLE=3600
# Seconds to wait for a connection before raising a timeout error
DB_POOL_TIMEOUT=30

# ── HTTPS / Proxy ─────────────────────────────────────────────────────────────
# Set to true when the backend is behind a TLS-terminating reverse proxy
# Enables the Strict-Transport-Security (HSTS) response header
HTTPS_BEHIND_PROXY=false

# ── Redis Cache ───────────────────────────────────────────────────────────────
# Default TTL in seconds for cached API responses
REDIS_CACHE_TTL=60

# ── Database Backup ───────────────────────────────────────────────────────────
# Directory path inside the backup container where dumps are stored
BACKUP_DEST_PATH=/backups
# Number of days to retain backup files before pruning
BACKUP_RETENTION_DAYS=7
# Seconds between backup runs (default: 86400 = 24 hours)
BACKUP_INTERVAL_SECONDS=86400

# ── Metrics ───────────────────────────────────────────────────────────────────
# Set to false to disable the /metrics Prometheus endpoint
METRICS_ENABLED=true

# ── Monitoring ────────────────────────────────────────────────────────────────
# Grafana admin password for docker-compose.monitoring.yml
GRAFANA_ADMIN_PASSWORD=change-me-in-production
# Alertmanager webhook URL for alert notifications
ALERTMANAGER_WEBHOOK_URL=http://localhost:9999/webhook

